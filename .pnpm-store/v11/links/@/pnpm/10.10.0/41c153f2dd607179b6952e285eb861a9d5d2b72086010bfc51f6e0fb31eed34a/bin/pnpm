#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
fi
# cmd-shim-target=/Users/waleedzahid/Desktop/projects/reviewflow-ai/.pnpm-store/v11/links/@/pnpm/10.10.0/41c153f2dd607179b6952e285eb861a9d5d2b72086010bfc51f6e0fb31eed34a/node_modules/pnpm/bin/pnpm.cjs
